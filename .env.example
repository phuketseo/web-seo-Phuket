# Copy to .env.local and fill in production values before deploy

# Site URL (used for metadataBase, canonical, sitemap)
NEXT_PUBLIC_SITE_URL=https://phuketseo.com

# Google Analytics 4 — replace placeholder before launch
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# LINE Official Account ID for chat widget
